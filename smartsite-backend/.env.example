# Copier vers .env et renseigner les valeurs : cp .env.example .env
# Groq : https://console.groq.com/
GROQ_API_KEY=your_groq_api_key
GROQ_API_KEY_FALLBACK=your_groq_api_key_fallback
GROQ_MODEL=llama-3.1-8b-instant
# Modèle vision (photos chantier / progress-photos) — liste : console Groq
GROQ_VISION_MODEL=meta-llama/llama-3.2-11b-vision-preview
GROQ_TIMEOUT_MS=10000
OPENROUTER_API_KEY=your_openrouter_api_key

# MongoDB (si pris en charge par votre app.module)
# MONGODB_URI=mongodb://127.0.0.1:27017/smartsite

# Tripo (génération 3D Dream House) — https://platform.tripo3d.ai/
# Clé secrète Plateforme (souvent préfixe tsk_). Ne pas mettre "Bearer" ni guillemets autour de la valeur.

TRIPO_API_KEY=your_tripo_api_key
# Version moteur Tripo (`model_version`). Défaut code : v3.1-20260211 (TRIPO_MODEL_VERSION_DEFAULT).
# Doc : https://platform.tripo3d.ai/docs/generation — ex. revenir en v2.5 : TRIPO_MODEL_VERSION=v2.5-20250123
# Ex. plus rapide : Turbo-v1.0-20250506
# TRIPO_MODEL_VERSION=v3.0-20250812
# Limite de faces (défaut code 72000 ; si TRIPO_QUAD=true, plafonné à 10000 côté requête). Max code : 200000
# TRIPO_FACE_LIMIT=120000
# Désactiver les textures (pas de texture_quality / pbr dans la requête). Défaut : textures on
# TRIPO_TEXTURE=false
# Avec textures : PBR (défaut true), qualités standard|detailed (API Tripo — pas de valeur « ultra »)
# TRIPO_PBR=false
# TRIPO_TEXTURE_QUALITY=detailed
# TRIPO_GEOMETRY_QUALITY=detailed
# Maillage quad (topologie plus propre ; face_limit borné). Défaut : false
# TRIPO_QUAD=true
#
# Qualité 3D (résumé) :
# - TRIPO_MODEL_VERSION : surcharge du défaut v3.1 si besoin (compte / crédits).
# - TRIPO_FACE_LIMIT + éventuellement TRIPO_QUAD=true (réduit les faces max. automatiquement).
# - TRIPO_TEXTURE=false pour aller plus vite sans matériaux.
# (Le suivi du statut Tripo se fait côté navigateur ; plus de TRIPO_POLL_* côté serveur.)
#
# Dream House : par défaut Tripo utilise image_to_model (1re image Pollinations) pour coller à la façade.
# Pour forcer uniquement text_to_model : DREAM_HOUSE_TRIPO_IMAGE_TO_MODEL=false

# Gemini (reformulation du prompt Tripo « text_to_model » — Dream House) — https://aistudio.google.com/apikey
# Si GEMINI_API_KEY est absent, le brouillon anglais interne (buildTripoPrompt) est envoyé tel quel à Tripo.
GEMINI_API_KEY=your_gemini_api_key
# Modèle (optionnel). Défaut code : gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash
# Désactiver la reformulation tout en gardant la clé : DREAM_HOUSE_GEMINI_REFINE=false

# Bot Telegram (optionnel)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_telegram_bot_username
